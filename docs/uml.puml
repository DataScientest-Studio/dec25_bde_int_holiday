@startuml Holiday_Itinerary_Architecture

title Holiday / POI Platform - Architecture (Updated)

' Make it look nicer
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam wrapWidth 220
skinparam maxMessageSize 120

package "Data Sources" {
  [DataTourisme API] as DataTourisme
  [Airports dataset\n(static / embedded)] as Airports
}

package "Extraction Layer" {
  [Batch ETL Pipeline\n(pipelines/*)] as ETL
  [Graph Loader\n(pipelines/*)] as GraphLoader
}

package "Storage Layer" {
  database "PostgreSQL" as Postgres {
    [poi table] as POITable
    [pipeline_runs table] as PipelineRuns
  }

  database "Neo4j" as Neo4j {
    [POI nodes] as POINodes
    [Type nodes] as TypeNodes
    [City nodes] as CityNodes
    [Department nodes] as DeptNodes
  }
}

package "API Layer (FastAPI)\n(src/api/main.py)" {
  [FastAPI Application] as API

  component "Core Endpoints" as CoreEndpoints
  component "Analytics Endpoints" as AnalyticsEndpoints
  component "Graph Endpoints" as GraphEndpoints
  component "ETL Control Endpoints" as ETLEndpoints
  component "Itinerary Endpoint\n/itinerary" as ItineraryEndpoint
  component "KMeans Airport Router\n/api/kmeans-airport/*" as KMeansEndpoints

  component "Analytics Functions\n(src/analytics/analytics.py)" as Analytics
  component "Clustering / ML\n(src/ml/*)" as ML
}

package "Frontend Layer" {
  [Streamlit Dashboard\n(src/dashboard/app.py)] as Dashboard
  [Streamlit Presentation\n(streamlit_app.py + pages/*)] as Presentation
}

package "Scheduler" {
  [Cron / Scheduler\n(Docker scheduler image)] as Scheduler
}

' =========================
' Data flow (ETL)
' =========================
DataTourisme --> ETL : Fetch POI data
ETL --> Postgres : Insert / update POIs\n+ pipeline_runs

Postgres --> GraphLoader : Read POIs
GraphLoader --> Neo4j : Create nodes / relationships

Scheduler --> ETL : Trigger (hourly / periodic)
Scheduler --> GraphLoader : Trigger after ETL

' =========================
' API access
' =========================
Postgres --> API : SQLAlchemy queries
Neo4j --> API : Graph queries

API --> Dashboard : HTTP JSON responses
API --> Presentation : (optional)\nlinks/docs rendering

' =========================
' Internal API structure
' =========================
API --> CoreEndpoints
API --> AnalyticsEndpoints
API --> GraphEndpoints
API --> ETLEndpoints
API --> ItineraryEndpoint
API --> KMeansEndpoints

AnalyticsEndpoints --> Analytics
CoreEndpoints --> Postgres
Analytics --> Postgres

GraphEndpoints --> Neo4j
ETLEndpoints --> ETL : run-now/status
ItineraryEndpoint --> Postgres : select POIs + coords
KMeansEndpoints --> ML : fit/predict clusters
ML --> Postgres : load POIs for clustering
ML --> Airports : map cluster center\nto nearest airport

' =========================
' Notes
' =========================
note right of Postgres
  **PostgreSQL schema (high level):**
  - poi (id, label, type, city, department_code, latitude, longitude, ...)
  - pipeline_runs (ETL run tracking)
end note

note right of Neo4j
  **Neo4j graph model:**
  - Nodes: :POI, :Type, :City, :Department
  - Relationships:
    - (:POI)-[:HAS_TYPE]->(:Type)
    - (:POI)-[:IN_CITY]->(:City)
    - (:POI)-[:IN_DEPARTMENT]->(:Department)
end note

note right of KMeansEndpoints
  **KMeans airport endpoints (stateless):**
  - GET /api/kmeans-airport/fit
  - GET /api/kmeans-airport/predict
end note

note right of Dashboard
  Dashboard pages call the API using API_BASE_URL
  (local: localhost, docker/k8s: service DNS name).
end note

@enduml